---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const { lang = "en", title = "SQMUSIC" } = Astro.props;
---

<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body style="margin:0; font-family:sans-serif; background:#0f0f0f; color:white;">

    <Header lang={lang} />

    <main style="padding:40px;">
      <slot />
    </main>

    <Footer />

  </body>
</html>
