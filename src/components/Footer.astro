---
const today = new Date();
---

<footer class="footer">
  <div class="footer-top">
    <p class="location">SQMUSIC — Global Music Project</p>

    <div class="footer-links">
      <div>
        <p class="title">Legal</p>
        <a href="#">Terms</a>
        <a href="#">Privacy</a>
        <a href="#">Cookies</a>
      </div>

      <div>
        <p class="title">Support</p>
        <a href="#">Shipping</a>
        <a href="#">Returns</a>
        <a href="#">Report</a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p>© {today.getFullYear()} SQMUSIC™. All rights reserved.</p>
  </div>
</footer>

<style>
.footer {
  padding: 60px 20px;
  background: #0a0a0a;
  color: #fff;
}

.footer-top {
  text-align: center;
  margin-bottom: 50px;
}

.location {
  color: #777;
  margin-bottom: 20px;
  font-size: 14px;
}

.footer-links {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 40px;
  max-width: 600px;
  margin: 0 auto;
}

.title {
  color: #aaa;
  margin-bottom: 10px;
  font-size: 14px;
}

.footer-links a {
  display: block;
  color: #666;
  margin-bottom: 8px;
  text-decoration: none;
  font-size: 13px;
}

.footer-links a:hover {
  color: #fff;
}

.footer-bottom {
  text-align: center;
  border-top: 1px solid #111;
  padding-top: 20px;
  font-size: 13px;
  color: #777;
}
</style>
