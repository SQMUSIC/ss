---
const today = new Date();
---

<footer class="footer">
  <div class="footer-top">
    <p class="location">
      Lyon, Rhône, Auvergne-Rhône-Alpes, France
    </p>

    <a href="https://maps.google.com" target="_blank" class="directions">
      Get directions →
    </a>

    <div class="socials">
      <a href="#"><i>YT</i></a>
      <a href="#"><i>IG</i></a>
      <a href="#"><i>X</i></a>
      <a href="#"><i>TT</i></a>
      <a href="#"><i>SC</i></a>
    </div>
  </div>

  <div class="footer-bottom">
    <p>© {today.getFullYear()} SQMUSIC. All Rights Reserved.</p>

    <div class="links">
      <a href="#">Terms & Conditions</a>
      <a href="#">Privacy Policy</a>
      <a href="#">Shipping & Payment Info</a>
      <a href="#">Return Policy</a>
      <a href="#">About Us</a>
      <a href="#">Cookie settings</a>
      <a href="#">Report abuse</a>
    </div>
  </div>
</footer>

<style>
.footer {
  background: #000;
  color: #ccc;
  text-align: center;
  padding: 60px 20px;
  font-family: sans-serif;
}

/* верх */
.footer-top {
  margin-bottom: 40px;
}

.location {
  font-size: 18px;
  margin-bottom: 10px;
}

.directions {
  display: inline-block;
  margin-bottom: 20px;
  color: #aaa;
  text-decoration: none;
  transition: 0.2s;
}

.directions:hover {
  color: #fff;
}

/* соцсети */
.socials {
  display: flex;
  justify-content: center;
  gap: 25px;
  font-size: 20px;
}

.socials a {
  color: #aaa;
  text-decoration: none;
}

.socials a:hover {
  color: #fff;
}

/* низ */
.footer-bottom p {
  margin-bottom: 20px;
  font-size: 16px;
}

/* ссылки как СЕТКА (не ломается) */
.links {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 10px;
  max-width: 700px;
  margin: 0 auto;
}

.links a {
  color: #aaa;
  text-decoration: none;
  font-size: 14px;
}

.links a:hover {
  color: #fff;
}
</style>
