---
const today = new Date();
---

<footer class="footer">
  <div class="footer-top">
    <p class="location">SQMUSIC — Global Music Project</p>

    <div class="footer-links">

      <!-- NAVIGATION -->
      <div>
        <p class="title">Navigation</p>
        <a href="/">Home</a>
        <a href="/shop">Shop</a>
        <a href="/contact">Contact</a>
        <a href="/about">About</a>
      </div>

      <!-- SUPPORT -->
      <div>
        <p class="title">Support</p>
        <a href="mailto:no-reply@support.shop.sqmusic.site">Store Help</a>
        <a href="/contact">Contact</a>
        <a href="mailto:artist@sqmusic.site">For Artists</a>
      </div>

      <!-- SOCIAL -->
      <div>
        <p class="title">Social</p>
        <a href="https://t.me/OFFICIAL_SQMUSIC" target="_blank">Telegram</a>
        <a href="https://audiomack.com/official_sqmusic" target="_blank">Audiomack</a>
        <a href="https://beacons.ai/official_sqmusic" target="_blank">Beacons</a>
      </div>

    </div>
  </div>

  <div class="footer-bottom">
    <p>© {today.getFullYear()} SQMUSIC™. All rights reserved.</p>
  </div>
</footer>

<style>
.footer {
  padding: 60px 20px;
  background: #0a0a0a;
  color: #fff;
}

.footer-top {
  text-align: center;
  margin-bottom: 50px;
}

.location {
  color: #777;
  margin-bottom: 20px;
  font-size: 14px;
}

.footer-links {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 40px;
  max-width: 850px;
  margin: 0 auto;
}

.title {
  color: #aaa;
  margin-bottom: 10px;
  font-size: 14px;
}

.footer-links a {
  display: block;
  color: #666;
  margin-bottom: 8px;
  text-decoration: none;
  font-size: 13px;
  transition: 0.2s;
}

.footer-links a:hover {
  color: #fff;
  transform: translateX(3px);
}

.footer-bottom {
  text-align: center;
  border-top: 1px solid #111;
  padding-top: 20px;
  font-size: 13px;
  color: #777;
}

/* 📱 mobile */
@media (max-width: 700px) {
  .footer-links {
    grid-template-columns: 1fr;
    text-align: center;
  }
}
</style>
