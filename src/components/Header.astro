---
const { lang = "en" } = Astro.props;
---

<header class="header">

  <a href={`/${lang}`} class="logo">SQMUSIC™</a>

  <nav class="nav">
    <a href={`/${lang}`}>
      {lang === "fr" ? "Accueil" : lang === "ru" ? "Главная" : "Home"}
    </a>

    <a href={`/${lang}/blog`}>Blog</a>

    <a href={`/${lang}/about`}>
      {lang === "fr" ? "À propos" : lang === "ru" ? "О нас" : "About"}
    </a>

    <a href={`/${lang}/shop`}>
      {lang === "fr" ? "Boutique" : lang === "ru" ? "Магазин" : "Shop"}
    </a>

    <a href={`/${lang}/contact`}>
      {lang === "fr" ? "Contact" : lang === "ru" ? "Контакты" : "Contact"}
    </a>
  </nav>

  <div class="right-side">
    <select onchange="window.location.href='/' + this.value">
      <option value="en" selected={lang === "en"}>EN</option>
      <option value="fr" selected={lang === "fr"}>FR</option>
      <option value="ru" selected={lang === "ru"}>RU</option>
    </select>
  </div>

</header>

<style>
.header {
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:22px 40px;
  background:white;
  border-bottom:1px solid #eee;
}

.logo {
  font-size:22px;
  font-weight:700;
  text-decoration:none;
  color:black;
}

.nav {
  display:flex;
  gap:35px;
}

.nav a {
  text-decoration:none;
  color:#111;
}

.right-side select {
  padding:6px 10px;
}
</style>
