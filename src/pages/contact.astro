---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Contact</title>
  </head>

  <body style="margin:0; background:#0f0f0f; color:white; font-family:sans-serif;">

    <Header />

    <main style="padding:40px;">

      <h1 data-i18n="contact_title">Contact</h1>

      <form style="
        display:flex;
        flex-direction:column;
        gap:15px;
        max-width:400px;
        margin-top:20px;
      ">

        <input
          type="text"
          placeholder="Name"
          data-placeholder-i18n="contact_name"
          style="padding:12px; border:none; border-radius:8px;"
        />

        <input
          type="email"
          placeholder="Email"
          data-placeholder-i18n="contact_email"
          style="padding:12px; border:none; border-radius:8px;"
        />

        <textarea
          placeholder="Message"
          data-placeholder-i18n="contact_message"
          style="padding:12px; border:none; border-radius:8px; min-height:120px;"
        ></textarea>

        <button
          type="submit"
          data-i18n="contact_send"
          style="
            padding:12px;
            border:none;
            border-radius:8px;
            background:#5A3D7F;
            color:white;
            cursor:pointer;
          "
        >
          Send
        </button>

      </form>

    </main>

    <Footer />

  </body>
</html>
