<html lang="en">
  <head>
    <title>Shop - SQMUSIC</title>
  </head>

  <body style="margin:0; font-family:sans-serif; background:#0f0f0f; color:white;">

    <!-- HEADER -->
    <header style="padding:20px; display:flex; gap:20px; border-bottom:1px solid #222;">
      <a href="/" style="color:white; text-decoration:none;">Home</a>
      <a href="/shop" style="color:white; text-decoration:none;">Shop</a>
      <a href="/contact" style="color:white; text-decoration:none;">Contact</a>
    </header>

    <!-- TITLE -->
    <main style="padding:20px;">
      <h1>🛍️ SQMUSIC SHOP</h1>
      <p>All products are available below</p>

      <!-- IFRAME SHOP -->
      <div style="margin-top:20px;">

        <iframe
          src="https://shop.sqmusic.site"
          style="width:100%; height:80vh; border:none; border-radius:12px;"
          loading="lazy"
          onerror="document.getElementById('fallback').style.display='block'"
        ></iframe>

        <!-- FALLBACK -->
        <div id="fallback" style="display:none; margin-top:20px;">
          <p>⚠️ Shop can't be loaded inside this page.</p>

          <a href="https://shop.sqmusic.site" target="_blank">
            <button style="padding:12px 20px; border:none; border-radius:8px; cursor:pointer;">
              Open Shop
            </button>
          </a>
        </div>

      </div>
    </main>

  </body>
</html>
