---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="SQMUSIC SHOP">

  <h1>🛍️ SHOP TEST (Telegram)</h1>
  <p>Trying to embed Telegram channel inside iframe</p>

  <iframe
    src="https://t.me/OFFICIAL_SQMUSIC"
    style="width:100%; height:80vh; border:none; border-radius:12px;"
    loading="lazy"
  ></iframe>

  <div style="margin-top:20px;">
    <p>⚠️ If nothing shows, Telegram blocks iframe embedding.</p>

    <a href="https://t.me/OFFICIAL_SQMUSIC" target="_blank">
      <button style="padding:12px 20px; border:none; border-radius:8px; cursor:pointer;">
        Open Telegram Channel
      </button>
    </a>
  </div>

</BaseLayout>
