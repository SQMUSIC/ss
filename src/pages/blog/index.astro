---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />

		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2rem);
				margin: 0 auto;
				padding: 40px 0;
			}

			/* BLOG POSTS */

			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}

			ul li {
				width: calc(50% - 1rem);
			}

			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}

			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}

			ul li:first-child img {
				width: 100%;
			}

			ul li:first-child .title {
				font-size: 2.369rem;
			}

			ul li img {
				width: 100%;
				margin-bottom: 0.5rem;
				border-radius: 16px;
			}

			ul li a {
				display: block;
			}

			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.2;
			}

			.date {
				margin-top: 8px;
				color: rgb(var(--gray));
			}

			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}

			ul a:hover img {
				box-shadow: var(--box-shadow);
			}

			/* SOCIAL FEED */

			.social-feed {
				margin-top: 100px;
			}

			.social-feed h2 {
				font-size: 2rem;
				margin-bottom: 30px;
			}

			.feed-grid {
				display: grid;
				gap: 24px;
			}

			.feed-card {
				padding: 24px;
				border-radius: 18px;
				background: white;
				border: 1px solid #ececec;
				transition: 0.2s ease;
			}

			.feed-card:hover {
				transform: translateY(-4px);
				box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
			}

			.feed-platform {
				display: inline-block;
				font-size: 14px;
				font-weight: 700;
				color: #5A3D7F;
				margin-bottom: 14px;
			}

			.feed-card p {
				margin: 0;
				line-height: 1.6;
				color: #444;
			}

			.feed-card a {
				display: inline-block;
				margin-top: 16px;
				color: #5A3D7F;
				text-decoration: none;
				font-weight: 600;
			}

			.feed-card a:hover {
				opacity: 0.8;
			}

			/* MOBILE */

			@media (max-width: 720px) {
				main {
					width: 100%;
				}

				ul {
					gap: 1rem;
				}

				ul li {
					width: 100%;
					text-align: center;
				}

				ul li:first-child {
					margin-bottom: 0;
				}

				ul li:first-child .title {
					font-size: 1.7rem;
				}

				.social-feed h2 {
					font-size: 1.6rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />

		<main>

			<!-- BLOG POSTS -->

			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<img
										width={720}
										height={360}
										src={post.data.heroImage}
										alt=""
									/>

									<h4 class="title">
										{post.data.title}
									</h4>

									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>

			<!-- SOCIAL FEED -->

			<section class="social-feed">
				<h2>Latest Updates</h2>

				<div class="feed-grid">

					<div class="feed-card">
						<span class="feed-platform">X / Twitter</span>

						<p>
							New experimental track currently in progress.
							More previews coming soon.
						</p>

						<a
							href="https://x.com/OFFICIALSQMUSIC"
							target="_blank"
						>
							Open X
						</a>
					</div>

					<div class="feed-card">
						<span class="feed-platform">Instagram</span>

						<p>
							Behind the scenes, visuals and updates from
							SQMUSIC.
						</p>

						<a
							href="https://instagram.com/official_sqmusic"
							target="_blank"
						>
							Open Instagram
						</a>
					</div>

					<div class="feed-card">
						<span class="feed-platform">Telegram</span>

						<p>
							Exclusive previews, snippets and direct project
							updates available on Telegram.
						</p>

						<a
							href="https://t.me/OFFICIAL_SQMUSIC"
							target="_blank"
						>
							Open Telegram
						</a>
					</div>

				</div>
			</section>

		</main>

		<Footer />
	</body>
</html>
